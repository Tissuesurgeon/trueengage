# Venice AI
VENICE_API_KEY=
VENICE_API_URL=https://api.venice.ai/api/v1/chat/completions

# 1Shot API (primary payout relayer — configure in 1Shot dashboard)
ONESHOT_API_KEY=
ONESHOT_API_SECRET=
ONESHOT_API_URL=https://api.1shotapi.com
# UUID of RewardEscrow.releaseReward contract method endpoint
ONESHOT_METHOD_ID=
# Optional: USDC transfer method + wallet for executeAsDelegator (delegated smart account payouts)
ONESHOT_DELEGATOR_METHOD_ID=
ONESHOT_WALLET_ID=
# Sepolia public relayer (primary live payout path — no Dev Platform method required)
ONESHOT_RELAYER_URL=https://relayer.1shotapi.dev/relayers

# Sepolia
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
CHAIN_ID=11155111
RELAYER_PRIVATE_KEY=

# Official Circle Sepolia USDC (default — do not use MockUSDC)
USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# Contract addresses (after deploy)
CAMPAIGN_MANAGER_ADDRESS=
SUBMISSION_MANAGER_ADDRESS=
REWARD_ESCROW_ADDRESS=
PLATFORM_TREASURY_ADDRESS=

# Database
# Local dev: docker compose -f docker/docker-compose.yml up postgres -d
DATABASE_URL=postgresql://trueengage:trueengage@localhost:5432/trueengage
# Render Postgres requires SSL: append ?sslmode=require to the connection string

# Backend
PORT=4000
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
NEXT_PUBLIC_BUNDLER_RPC_URL=https://api.pimlico.io/v2/sepolia/rpc?apikey=YOUR_PIMLICO_API_KEY
NEXT_PUBLIC_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
NEXT_PUBLIC_PLATFORM_TREASURY_ADDRESS=
